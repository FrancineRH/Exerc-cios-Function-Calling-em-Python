#Exercício 1 - Calculadora Simples
import re

def somar(a, b):
    return a + b

def multiplicar(a, b):
    return a * b


def calcular(mensagem):
    mensagem = mensagem.lower()

    numeros = re.findall(r'\d+', mensagem)

    if len(numeros) < 2:
        return "Não consegui encontrar dois números."

    a = int(numeros[0])
    b = int(numeros[1])

    if '+' in mensagem:
        resultado = somar(a, b)
        return f"O resultado de {a} + {b} é {resultado}."

    elif 'multiplique' in mensagem or 'multiplicar' in mensagem:
        resultado = multiplicar(a, b)
        return f"O resultado de {a} * {b} é {resultado}."

    else:
        return "Desculpe, não entendi a operação."

mensagem = input("Digite sua pergunta: ")
print(calcular(mensagem))
