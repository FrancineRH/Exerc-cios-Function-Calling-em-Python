import re

def somar(a, b):
    return a + b

def subtrair(a, b):
    return a - b

def multiplicar(a, b):
    return a * b

def dividir(a, b):
    return a / b


mensagem = input("Digite sua pergunta: ").lower()

numeros = list(map(float, re.findall(r'\d+', mensagem)))

a = numeros[0]
b = numeros[1]

if "+" in mensagem or "mais" in mensagem:
    resultado = somar(a, b)

elif "menos" in mensagem or "-" in mensagem:
    resultado = subtrair(a, b)

elif "multiplique" in mensagem or "multiplicar" in mensagem or "vezes" in mensagem or "x" in mensagem:
    resultado = multiplicar(a, b)

elif "dividido" in mensagem or "dividir" in mensagem or "/" in mensagem:
    resultado = dividir(a, b)

else:
    resultado = "Operação não reconhecida"

print("Resultado:", resultado)
