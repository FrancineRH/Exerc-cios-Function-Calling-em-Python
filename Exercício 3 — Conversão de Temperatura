import re

def celsius_para_fahrenheit(c):
    return (c * 9/5) + 32

def fahrenheit_para_celsius(f):
    return (f - 32) * 5/9


mensagem = input("Digite sua pergunta: ").lower()

numero = float(re.findall(r'\d+', mensagem)[0])

if "celsius" in mensagem and "fahrenheit" in mensagem:
    resultado = celsius_para_fahrenheit(numero)
    print(f"Resultado: {resultado:.2f} °F")

elif "f" in mensagem and "celsius" in mensagem:
    resultado = fahrenheit_para_celsius(numero)
    print(f"Resultado: {resultado:.2f} °C")

elif "fahrenheit" in mensagem and "celsius" in mensagem:
    resultado = fahrenheit_para_celsius(numero)
    print(f"Resultado: {resultado:.2f} °C")

else:
    print("Não consegui identificar a conversão.")
